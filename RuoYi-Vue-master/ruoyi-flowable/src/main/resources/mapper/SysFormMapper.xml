<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.flowable.mapper.SysFormMapper">

    <resultMap type="SysForm" id="SysFormResult">
        <id     property="id"           column="id"            />
        <result property="formName"     column="form_name"     />
        <result property="formCode"     column="form_code"     />
        <result property="formJson"     column="form_json"     />
        <result property="formDesc"     column="form_desc"     />
        <result property="status"       column="status"        />
        <result property="createBy"     column="create_by"     />
        <result property="createTime"   column="create_time"   />
        <result property="updateBy"     column="update_by"     />
        <result property="updateTime"   column="update_time"   />
        <result property="remark"       column="remark"        />
    </resultMap>

    <sql id="selectFormVo">
        select id, form_name, form_code, form_json, form_desc, status, create_by, create_time, update_by, update_time, remark
        from sys_form
    </sql>

    <select id="selectFormList" parameterType="SysForm" resultMap="SysFormResult">
        <include refid="selectFormVo"/>
        <where>
            <if test="formName != null and formName != ''">
                AND form_name like concat('%', #{formName}, '%')
            </if>
            <if test="formCode != null and formCode != ''">
                AND form_code = #{formCode}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        order by create_time desc
    </select>

    <select id="selectFormById" parameterType="Long" resultMap="SysFormResult">
        <include refid="selectFormVo"/>
        where id = #{id}
    </select>

    <insert id="insertForm" parameterType="SysForm" useGeneratedKeys="true" keyProperty="id">
        insert into sys_form
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="formName != null and formName != ''">form_name,</if>
            <if test="formCode != null and formCode != ''">form_code,</if>
            <if test="formJson != null and formJson != ''">form_json,</if>
            <if test="formDesc != null and formDesc != ''">form_desc,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time,
            <if test="remark != null and remark != ''">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="formName != null and formName != ''">#{formName},</if>
            <if test="formCode != null and formCode != ''">#{formCode},</if>
            <if test="formJson != null and formJson != ''">#{formJson},</if>
            <if test="formDesc != null and formDesc != ''">#{formDesc},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate(),
            <if test="remark != null and remark != ''">#{remark},</if>
        </trim>
    </insert>

    <update id="updateForm" parameterType="SysForm">
        update sys_form
        <trim prefix="SET" suffixOverrides=",">
            <if test="formName != null and formName != ''">form_name = #{formName},</if>
            <if test="formCode != null and formCode != ''">form_code = #{formCode},</if>
            <if test="formJson != null and formJson != ''">form_json = #{formJson},</if>
            <if test="formDesc != null and formDesc != ''">form_desc = #{formDesc},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteFormById" parameterType="Long">
        delete from sys_form where id = #{id}
    </delete>

    <delete id="deleteFormByIds" parameterType="Long">
        delete from sys_form where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>
